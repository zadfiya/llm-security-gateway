APP_ENV=development

# LLM Provider: openai | groq | ollama
LLM_PROVIDER=ollama

# API Keys (use Azure Key Vault in production — never commit real keys)
OPENAI_API_KEY=
GROQ_API_KEY=''
OLLAMA_BASE_URL=http://localhost:11434


# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60


# TODO API Keys

# TODO Azure Key Vault
USE_KEYVAULT=false